# Secrets. Store real values in GitHub Environment Secrets, Kubernetes Secret,
# Helm private values, Vault, or another secret manager. Do not commit real values.
JWT_SECRET=replace-with-strong-random-secret-at-least-32-bytes
INTERNAL_API_TOKEN=replace-with-strong-random-internal-token
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
APP_BOOTSTRAP_ADMIN_EMAIL=admin@your-domain.com
APP_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password

# Local Docker Compose database credentials. Keep production/stage database
# credentials in GitHub Environment Secrets, Kubernetes Secret, Helm private
# values, Vault, or another secret manager.
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=auth
USER_DB_USER=user
USER_DB_PASSWORD=user
TASK_DB_USER=task
TASK_DB_PASSWORD=task
CLIENT_DB_USER=client
CLIENT_DB_PASSWORD=client

# Runtime configuration. These can usually be GitHub Environment Variables,
# Kubernetes ConfigMap values, or Helm config.* values.
SPRING_PROFILES_ACTIVE=dev
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
FRONTEND_OAUTH_SUCCESS_URL=http://localhost:3000/auth/callback
OAUTH_LOGIN_CODE_TTL_SECONDS=300
OAUTH_LOGIN_CODE_CLEANUP_DELAY_MS=300000
OAUTH_LOGIN_CODE_CLEANUP_INITIAL_DELAY_MS=60000
JWT_EXP_MINUTES=60
JWT_REFRESH_DAYS=14
PUBLIC_REGISTRATION_ENABLED=true
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX_ATTEMPTS=60
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_BLOCK_SECONDS=300
WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://localhost:5173,http://198.18.0.1:3000
APP_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Optional local ports
GATEWAY_PORT=8080
AUTH_PORT=8081
USER_PORT=8082
TASK_PORT=8083
CLIENT_PORT=8084
AUTH_DB_HOST_PORT=5433
USER_DB_HOST_PORT=5434
TASK_DB_HOST_PORT=5435
CLIENT_DB_HOST_PORT=5436

# Optional local service URLs
USER_SERVICE_URL=http://user-service:8082
TASK_SERVICE_URL=http://task-service:8083

# Optional upload directories
USER_AVATARS_DIR=uploads/user-avatars
TASK_ATTACHMENTS_DIR=uploads/task-attachments
CLIENT_ATTACHMENTS_DIR=uploads/client-attachments
